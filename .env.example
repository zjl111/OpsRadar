OPSRADAR_ENV=production
OPSRADAR_SECRET_KEY=replace-with-a-long-random-jwt-secret
OPSRADAR_ENCRYPTION_KEY=replace-with-a-long-random-credential-encryption-key
OPSRADAR_API_WORKERS=2
OPSRADAR_WORKER_CONCURRENCY=2
OPSRADAR_SSH_CONNECT_TIMEOUT=10
OPSRADAR_SSH_COMMAND_TIMEOUT=30
OPSRADAR_MAX_TASK_SECONDS=3600
OPSRADAR_PUBLIC_BASE_URL=https://opsradar.example.com
OPSRADAR_TLS_DIR=./deploy/certs

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

HTTP_PORT=80
HTTPS_PORT=443

OPSRADAR_ADMIN_USERNAME=admin
OPSRADAR_ADMIN_PASSWORD=change-this-admin-password
OPSRADAR_ADMIN_DISPLAY_NAME=OpsRadar Admin
OPSRADAR_ADMIN_EMAIL=admin@example.com
